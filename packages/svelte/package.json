{
  "name": "@jboltai/tokui-svelte",
  "version": "0.1.8",
  "description": "TokUI Svelte adapter — use:tokui action and TokUI component for streaming DSL UI.",
  "license": "MIT",
  "author": "sdxiaomu (https://jboltai.com)",
  "homepage": "https://github.com/jboltai/tokui",
  "repository": {
    "type": "git",
    "url": "https://github.com/jboltai/tokui.git",
    "directory": "packages/svelte"
  },
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "svelte": "src/TokUI.svelte",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "svelte": "./src/TokUI.svelte",
      "import": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./action": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@jboltai/tokui": "workspace:^"
  },
  "peerDependencies": {
    "svelte": ">=3.46.0"
  },
  "peerDependenciesMeta": {
    "svelte": { "optional": false }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "tokui",
    "svelte",
    "streaming-ui",
    "dsl",
    "action"
  ],
  "publishConfig": {
    "access": "public"
  }
}
