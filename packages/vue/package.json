{
  "name": "@jboltai/tokui-vue",
  "version": "0.1.8",
  "description": "TokUI Vue 3 adapter — <TokUIView> component and useTokUIStream() composable for streaming DSL UI.",
  "license": "MIT",
  "author": "sdxiaomu (https://jboltai.com)",
  "homepage": "https://github.com/jboltai/tokui",
  "repository": {
    "type": "git",
    "url": "https://github.com/jboltai/tokui.git",
    "directory": "packages/vue"
  },
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@jboltai/tokui": "workspace:^"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": { "optional": false }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "tokui",
    "vue",
    "vue3",
    "streaming-ui",
    "dsl",
    "composable"
  ],
  "publishConfig": {
    "access": "public"
  }
}
